{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=your-production-server;Database=MarketPriceComparisonSystemDatabase;User Id=your-user;Password=your-password;TrustServerCertificate=True;"
